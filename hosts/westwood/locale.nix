{ config, lib, pkgs, ... }:

# ==============================================================================
# 本地化配置
#
#   本文件管理系统的区域设置（Locale）和中文输入法，涵盖：
#   - 时区（time.timeZone）：设定系统时钟的参考时区
#   - 语言环境（i18n）：决定系统界面、排序规则和日期格式的语言
#   - 控制台（console）：TTY 终端下的字体和键盘布局
#   - 输入法（i18n.inputMethod）：图形界面下的文本输入引擎
#
#   当前配置以中国大陆使用场景为基准（北京时间 + 简体中文 + Fcitx5+Rime）。
# ==============================================================================

{
  # ============================================================================
  # 时区与语言
  # ============================================================================
  time.timeZone = "Asia/Shanghai";                     # 时区 = 北京时间（UTC+8，无夏令时）
  i18n.defaultLocale = "zh_CN.UTF-8";                  # 系统默认语言：简体中文 UTF-8 编码

  # --------------------------------------------------------------------------
  # 控制台设置（仅影响 TTY 文本终端，不影响图形界面）
  #   useXkbConfig = true 表示复用 X11/Wayland 的键盘布局配置（由桌面环境管理）
  # --------------------------------------------------------------------------
  console = {
    font = "${pkgs.terminus_font}/share/consolefonts/ter-u28n.psf.gz";  # 控制台等宽字体
    useXkbConfig = true;                               # 复用图形界面的键盘布局
  };

  # ============================================================================
  # 中文输入法 —— Fcitx5 + 中州韵（Rime）+ 雾凇拼音词库
  #
  #   Fcitx5：    现代输入法框架，支持 GTK/Qt 应用的输入法集成
  #   Rime：      高度可定制的输入法引擎（中州韵），支持拼音/五笔/仓颉等
  #   rime-ice：  基于 Rime 的雾凇拼音词库，词库新且准确率高
  #
  #   输入法切换快捷键：
  #     Ctrl+Space    → 切换中/英输入
  #     Ctrl+Shift+P  → 切换输入方案（拼音/五笔等）
  #     F4            → Rime 菜单
  # ============================================================================
  i18n.inputMethod = {
    type = "fcitx5";
    enable = true;
    fcitx5.addons = with pkgs; [
      fcitx5-rime                                    # Rime 输入法引擎（核心）
      kdePackages.fcitx5-chinese-addons              # Fcitx5 中文扩展（拼音/双拼/五笔/手写）
      rime-ice                                        # 雾凇拼音词库 —— 现代简体中文优化
    ];
  };

  # --------------------------------------------------------------------------
  # 输入法环境变量
  #   确保不同工具包的应用能正确调用 Fcitx5：
  #   - GTK_IM_MODULE  → GTK2/3/4 应用
  #   - QT_IM_MODULE   → Qt5/Qt6 应用
  #   - XMODIFIERS     → X11 应用标准输入法接口（XWayland 兼容）
  # --------------------------------------------------------------------------
  environment.sessionVariables = {
    GTK_IM_MODULE = "fcitx";
    QT_IM_MODULE = "fcitx";
    XMODIFIERS = "@im=fcitx";
  };
}
