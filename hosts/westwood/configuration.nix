# ==============================================================================
# 主机：westwood —— 系统配置入口
#   本文件作为 hosts/westwood/ 的模块入口，imports 各子模块。
#   子模块按职责拆分：网络、本地化、硬件、桌面、软件包。
#   共享配置（镜像源、用户定义等）见 modules/common.nix。
# ==============================================================================

{
  imports = [
    ./hardware-configuration.nix   # 硬件配置（自动生成，勿修改）
    ./networking.nix               # 网络、主机名、SSH
    ./locale.nix                   # 时区、语言、输入法
    ./hardware.nix                 # 引导、NVIDIA 显卡、交换空间
    ./desktop.nix                  # niri、GNOME、字体
    ./packages.nix                 # 系统软件包
    ./flatpak.nix                  # Flatpak 容器化应用框架（中科大源）
  ];

  # ============================================================================
  # 系统版本（不要修改！用于向后兼容判定）
  # ============================================================================
  system.stateVersion = "25.11";
}
