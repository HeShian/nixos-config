{ config, lib, pkgs, ... }:

# ==============================================================================
# 蓝牙配置
#
#   本文件管理 westwood 主机的蓝牙硬件支持。
#
#   协议栈：bluez
#   上层管理：由 DMS（DankMaterialShell）通过 bluez DBus API 直接操控
#   DMS 自带蓝牙管理界面 → 不需要额外安装 blueman
# ==============================================================================

{
  hardware.bluetooth = {
    enable = true;                                  # 启用蓝牙硬件
    powerOnBoot = true;                             # 开机自动开启蓝牙适配器
  };
}
